/* pages/mine/mine.wxss - 我的页面样式 */

/* 用户信息卡片 */
.user-card {
  padding: 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-info.not-login {
  flex-direction: column;
  text-align: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin-right: 24rpx;
}

.not-login .avatar {
  margin-right: 0;
  margin-bottom: 20rpx;
}

.info-content {
  flex: 1;
}

.not-login .info-content {
  margin-bottom: 30rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.user-phone {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.edit-btn {
  padding: 12rpx 24rpx;
  border: 1rpx solid var(--primary-color);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--primary-color);
}

.btn-small {
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  margin: 0;
}

/* 考勤信息卡片 */
.attendance-info {
  padding: 30rpx;
}

.info-header {
  margin-bottom: 24rpx;
}

.info-grid {
  display: flex;
  justify-content: space-between;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.info-value {
  font-size: 40rpx;
  font-weight: bold;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 功能菜单 */
.menu-section, .admin-section {
  padding: 0;
}

.section-title {
  font-size: 26rpx;
  color: #999;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-value {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-section {
  margin-top: 40rpx;
  padding: 0 30rpx;
}

.btn-logout {
  background: #fff;
  color: #666;
  border: 1rpx solid #e5e5e5;
}

/* 编辑弹窗 */
.edit-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.edit-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transition: transform 0.3s;
}

.edit-modal.show .modal-content {
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  text-align: center;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  padding: 30rpx;
}

.edit-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.edit-row:last-child {
  margin-bottom: 0;
}

.edit-label {
  font-size: 28rpx;
  color: #333;
  width: 140rpx;
}

.edit-input {
  flex: 1;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-footer .btn {
  flex: 1;
  margin: 0;
}

.btn-default {
  background: #f5f5f5;
  color: #666;
}

/* 规则弹窗 */
.rule-modal .modal-body {
  padding: 20rpx 30rpx;
}

.rule-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rule-item:last-child {
  border-bottom: none;
}

.rule-label {
  font-size: 28rpx;
  color: #666;
}

.rule-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}