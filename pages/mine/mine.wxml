<!-- pages/mine/mine.wxml - 我的页面 -->
<view class="page-container">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-info" wx:if="{{isLogin}}">
      <image class="avatar" src="{{userInfo.avatar || '/assets/icons/default_avatar.png'}}" mode="aspectFill"></image>
      <view class="info-content">
        <text class="user-name">{{userInfo.name || '未设置姓名'}}</text>
        <text class="user-phone">{{userInfo.phone || '未绑定手机'}}</text>
      </view>
      <view class="edit-btn" bindtap="onEditProfile">
        <text>编辑</text>
      </view>
    </view>
    
    <!-- 未登录状态 -->
    <view class="user-info not-login" wx:if="{{!isLogin}}">
      <image class="avatar" src="/assets/icons/default_avatar.png" mode="aspectFill"></image>
      <view class="info-content">
        <text class="user-name">未登录</text>
        <text class="user-phone">点击下方按钮登录</text>
      </view>
      <button class="btn btn-primary btn-small" bindtap="onLogin">登录</button>
    </view>
  </view>

  <!-- 考勤信息 -->
  <view class="attendance-info card">
    <view class="info-header">
      <text class="title">考勤信息</text>
    </view>
    <view class="info-grid">
      <view class="info-item">
        <text class="info-value">{{attendanceInfo.workDays}}</text>
        <text class="info-label">应到天数</text>
      </view>
      <view class="info-item">
        <text class="info-value text-success">{{attendanceInfo.presentDays}}</text>
        <text class="info-label">实际出勤</text>
      </view>
      <view class="info-item">
        <text class="info-value text-error">{{attendanceInfo.lateDays + attendanceInfo.earlyDays}}</text>
        <text class="info-label">异常次数</text>
      </view>
      <view class="info-item">
        <text class="info-value text-secondary">{{attendanceInfo.absentDays}}</text>
        <text class="info-label">缺卡天数</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="onEditProfile">
      <text class="menu-icon">👤</text>
      <text class="menu-text">个人信息</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onCheckInRule">
      <text class="menu-icon">⏰</text>
      <text class="menu-text">考勤规则</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onLocationSet">
      <text class="menu-icon">📍</text>
      <text class="menu-text">考勤地点</text>
      <text class="menu-value">{{config.location.name || '未设置'}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于系统</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 管理入口（管理员可见） -->
  <view class="admin-section card" wx:if="{{isAdmin && isLogin}}">
    <view class="section-title">管理功能</view>
    <view class="menu-item" bindtap="onUserManagement">
      <text class="menu-icon">👥</text>
      <text class="menu-text">成员管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onLocationSet">
      <text class="menu-icon">🗺️</text>
      <text class="menu-text">地点设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onConfigSet">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">系统配置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <button class="btn btn-logout" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 编辑信息弹窗 -->
  <view class="edit-modal {{showEditModal ? 'show' : ''}}" wx:if="{{showEditModal}}">
    <view class="modal-mask" bindtap="onCloseEditModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">编辑个人信息</text>
      </view>
      
      <view class="modal-body">
        <view class="edit-row">
          <text class="edit-label">姓名</text>
          <input 
            class="edit-input"
            placeholder="请输入姓名"
            value="{{editForm.name}}"
            bindinput="onNameInput"
          />
        </view>
        
        <view class="edit-row">
          <text class="edit-label">手机号</text>
          <input 
            class="edit-input"
            type="number"
            maxlength="11"
            placeholder="请输入手机号"
            value="{{editForm.phone}}"
            bindinput="onPhoneInput"
          />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn btn-default" bindtap="onCloseEditModal">取消</button>
        <button class="btn btn-primary" bindtap="onSaveProfile">保存</button>
      </view>
    </view>
  </view>

  <!-- 考勤规则弹窗 -->
  <view class="rule-modal {{showRuleModal ? 'show' : ''}}" wx:if="{{showRuleModal}}">
    <view class="modal-mask" bindtap="onCloseRuleModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">考勤规则</text>
      </view>
      
      <view class="modal-body">
        <view class="rule-item">
          <text class="rule-label">上班时间</text>
          <text class="rule-value">{{config.workStartTime}}</text>
        </view>
        <view class="rule-item">
          <text class="rule-label">下班时间</text>
          <text class="rule-value">{{config.workEndTime}}</text>
        </view>
        <view class="rule-item">
          <text class="rule-label">考勤半径</text>
          <text class="rule-value">{{config.location.radius}}米</text>
        </view>
        <view class="rule-item">
          <text class="rule-label">考勤地点</text>
          <text class="rule-value">{{config.location.name}}</text>
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn btn-primary" bindtap="onCloseRuleModal">我知道了</button>
      </view>
    </view>
  </view>
</view>