/* pages/index/index.wxss - 打卡首页完整样式 */

/* ========== 全局容器 ========== */
.page-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
  padding-bottom: 40rpx;
}

/* ========== 卡片通用 ========== */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

/* ========== 登录提示 ========== */
.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 60rpx 40rpx;
}
.login-tip-content .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
}
.login-tip-content .subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 12rpx;
}
.login-tip .btn-primary {
  margin-top: 40rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 60rpx;
  padding: 20rpx 60rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
}

/* ========== 时间卡片 ========== */
.time-card {
  text-align: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}
.current-date {
  font-size: 32rpx;
  opacity: 0.9;
}
.current-time {
  font-size: 72rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin: 12rpx 0 6rpx;
}
.current-week {
  font-size: 28rpx;
  opacity: 0.8;
}

/* ========== 状态卡片 ========== */
.status-card {
  padding-bottom: 20rpx;
}
.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
}
.status-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}
.status-date {
  font-size: 26rpx;
  color: #888;
}

/* 记录列表 */
.record-list {
  margin: 10rpx 0 16rpx;
}
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.record-item:last-child {
  border-bottom: none;
}
.record-time {
  font-size: 30rpx;
  font-weight: 500;
  width: 100rpx;
  color: #333;
}
.record-type {
  font-size: 28rpx;
  flex: 1;
  margin-left: 20rpx;
}
.record-type.in {
  color: #52c41a;
}
.record-type.out {
  color: #ff4d4f;
}
.record-status {
  font-size: 24rpx;
}
.no-record {
  text-align: center;
  color: #bbb;
  padding: 24rpx 0;
  font-size: 28rpx;
}

/* 状态标签 */
.status-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  flex-wrap: wrap;
}
.tag {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}
.tag-success {
  background: #52c41a;
}
.tag-error {
  background: #ff4d4f;
}
.tag-warning {
  background: #faad14;
}
.tag-default {
  background: #d9d9d9;
  color: #666;
}

/* ========== 打卡区域 ========== */
.checkin-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.buttons-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #666;
}
.location-info {
  color: #1890ff;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.location-icon {
  font-size: 28rpx;
}

.btn-checkin {
  width: 80%;
  margin: 10rpx auto 20rpx;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  color: #fff;
  font-size: 38rpx;
  font-weight: bold;
  border-radius: 60rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
  transition: all 0.2s;
}
.btn-checkin:active {
  transform: scale(0.96);
  opacity: 0.85;
}

/* 打卡结果提示 */
.checkin-result {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #f6f8fa;
  border-radius: 40rpx;
  width: 100%;
}
.result-icon {
  font-size: 40rpx;
}
.result-text {
  font-size: 28rpx;
  color: #333;
}
.result-icon.success {
  color: #52c41a;
}
.result-icon.error {
  color: #ff4d4f;
}
.result-icon.warning {
  color: #faad14;
}

/* ========== 快速操作 ========== */
.quick-actions {
  padding: 10rpx 0;
}
.action-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.action-item:last-child {
  border-bottom: none;
}
.action-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.action-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a2e;
}
.action-arrow {
  color: #ccc;
  font-size: 28rpx;
}

/* ========== 定位信息 ========== */
.location-card {
  font-size: 26rpx;
  color: #666;
}
.location-row {
  display: flex;
  margin: 8rpx 0;
}
.location-label {
  width: 170rpx;
  color: #999;
}
.location-value {
  flex: 1;
  word-break: break-all;
}
.text-success {
  color: #52c41a;
}
.text-error {
  color: #ff4d4f;
}

/* 配对记录样式 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.pair-info {
  font-size: 30rpx;
  color: #333;
}
.duration {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 500;
}