.admin-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
  box-sizing: border-box;
}

.no-auth {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
}
.no-auth .icon {
  font-size: 120rpx;
}
.no-auth .title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-top: 30rpx;
}
.no-auth .desc {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 0;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}
.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.filter-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.filter-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.filter-item .label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666;
}
.filter-item .picker {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}
.btn-filter {
  width: 100%;
  margin-top: 10rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 60rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  border: none;
}

.record-table {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  height: 55vh;
}
.table-header {
  display: flex;
  background: #f0f2f5;
  padding: 20rpx 16rpx;
  font-weight: bold;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #eee;
}
.table-body {
  height: calc(100% - 80rpx);
  padding: 0 16rpx;
}
.table-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 26rpx;
  color: #333;
}
.table-row:last-child {
  border-bottom: none;
}
.col-date { flex: 0 0 140rpx; }
.col-user { flex: 0 0 120rpx; }
.col-time { flex: 0 0 100rpx; }
.col-duration { flex: 0 0 100rpx; color: #1890ff; font-weight: 500; }
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #bbb;
  font-size: 28rpx;
}

/* ===== 应到天数卡片特殊样式 ===== */
.secret-card {
  border: 2rpx dashed #1890ff;
  background: #f0f9ff;
  cursor: pointer;
  transition: all 0.2s;
}
.secret-card:active {
  transform: scale(0.95);
  background: #d6eeff;
}
.badge {
  display: block;
  font-size: 20rpx;
  color: #1890ff;
  margin-top: 4rpx;
}
.admin-badge {
  color: #52c41a;
}
.tap-progress {
  display: block;
  font-size: 24rpx;
  color: #ff7a00;
  margin-top: 4rpx;
  font-weight: bold;
}
.auth-tip {
  text-align: center;
  font-size: 28rpx;
  color: #ff7a00;
  background: #fff7e6;
  padding: 16rpx 0;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #ffd591;
}