.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

.map-section {
  margin: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-buttons {
  display: flex;
  justify-content: space-around;
  margin: 20rpx;
}

.btn-outline {
  flex: 1;
  margin: 0 10rpx;
  font-size: 26rpx;
  color: #1890ff;
  background-color: #fff;
  border: 1rpx solid #1890ff;
  border-radius: 8rpx;
}

.info-card {
  margin: 20rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-item {
  margin-bottom: 25rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input-field {
  width: 100%;
  height: 70rpx;
  padding: 0 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 25rpx;
}

.info-half {
  flex: 1;
}

.info-half:first-child {
  margin-right: 20rpx;
}

.value {
  display: block;
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 20rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.radius-input {
  display: flex;
  align-items: center;
}

.radius-input .input-field {
  flex: 1;
}

.unit {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #999;
}

.footer {
  margin: 40rpx 20rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-bottom: 20rpx;
}

.btn-default {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #fff;
  color: #666;
  font-size: 32rpx;
  border-radius: 44rpx;
  border: 1rpx solid #e0e0e0;
}