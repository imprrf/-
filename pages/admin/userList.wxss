/* pages/admin/userList.wxss - 成员管理页面样式 */

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.search-btn {
  padding: 16rpx 32rpx;
  background: var(--primary-color);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  margin: 0;
}

/* 成员卡片 */
.user-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: flex-start;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.user-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.user-phone {
  font-size: 26rpx;
  color: #666;
  margin-top: 6rpx;
}

.user-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.user-actions {
  /* 操作区域 */
}

/* 用户统计 */
.user-footer {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stat-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.action-row {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--primary-color);
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
  color: var(--text-placeholder);
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
}