<!-- pages/admin/admin.wxml - 系统配置页面 -->
<view class="page-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">系统配置</text>
  </view>

  <!-- 通用设置 -->
  <view class="card">
    <view class="card-title">
      <text class="title-text">通用设置</text>
    </view>
    <view class="setting-list">
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">🔔</text>
          <text class="setting-label">消息通知提醒</text>
        </view>
        <switch checked disabled color="#1890ff" />
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">📍</text>
          <text class="setting-label">打卡自动定位</text>
        </view>
        <switch checked disabled color="#1890ff" />
      </view>
      <view class="setting-item">
        <view class="setting-left">
          <text class="setting-icon">🗑️</text>
          <text class="setting-label">清除本地缓存</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 管理员后台 -->
  <view class="card" wx:if="{{isAdmin}}">
    <view class="card-title">
      <text class="title-text">👑 团队打卡总览</text>
      <text class="subtitle">今日最新打卡记录</text>
    </view>
    
    <scroll-view scroll-y class="records-scroll" wx:if="{{memberRecords.length > 0}}">
      <view class="record-item" wx:for="{{memberRecords}}" wx:key="_id">
        <view class="record-header">
          <view class="user-info">
            <text class="user-name">{{item.userName || item.user || '未知成员'}}</text>
            <text class="user-date">{{item.date || ''}}</text>
          </view>
          <view class="status-badge">
            {{item.status === 'Complete' || item.clockOut ? '已完成' : '进行中'}}
          </view>
        </view>
        
        <view class="record-body">
          <view class="time-group">
            <view class="time-item">
              <text class="time-label">上班签到</text>
              <text class="time-value">{{item.clockIn || item.checkInTime || '--:--'}}</text>
            </view>
            <view class="time-divider"></view>
            <view class="time-item">
              <text class="time-label">下班签退</text>
              <text class="time-value">{{item.clockOut || item.checkOutTime || '--:--'}}</text>
            </view>
          </view>
          
          <view class="duration-row" wx:if="{{item.duration || item.totalWorkTime}}">
            <text class="duration-text">⏱️ 工作时长：{{item.duration ? (item.duration + '分钟') : (item.totalWorkTime || '--')}}</text>
          </view>
          
          <view class="location-row" wx:if="{{item.locationIn && item.locationIn.address || item.checkInLocation && item.checkInLocation.name}}">
            <text class="location-text">📍 {{item.locationIn && item.locationIn.address || item.checkInLocation && item.checkInLocation.name || '未知位置'}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    
    <view class="empty-state" wx:else>
      <text class="empty-icon">📂</text>
      <text class="empty-text">今天暂时还没有打卡记录</text>
    </view>
  </view>

  <!-- 页面底部 -->
  <view class="page-footer">
    <text class="copyright">© 璧山机电大学高能束实验室</text>
    <text class="version" bindtap="tapSystemConfig">当前系统版本 v1.0.6 (Build 2026)</text>
  </view>
</view>
