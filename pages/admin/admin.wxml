<!-- 成员管理后台 + 点击“应到天数”10次激活 -->
<view class="admin-container">

<!-- ===== 统计卡片（始终显示） ===== -->
<view class="stats-grid">
  <!-- 总打卡次数 -->
  <view class="stat-card">
    <text class="stat-num">{{totalRecords || 0}}</text>
    <text class="stat-label">总打卡次数</text>
  </view>

  <!-- 总在岗时长 -->
  <view class="stat-card">
    <text class="stat-num">{{totalHours || '0'}}h</text>
    <text class="stat-label">总在岗时长</text>
  </view>

  <!-- 今日打卡 -->
  <view class="stat-card">
    <text class="stat-num">{{todayCount || 0}}</text>
    <text class="stat-label">今日打卡</text>
  </view>

  <!-- 应到天数（点击10次激活） -->
  <view class="stat-card secret-card" bindtap="onSecretTap">
    <text class="stat-num">{{shouldWorkDays || '--'}}</text>
    <text class="stat-label">
      应到天数
      <text wx:if="{{!isAdmin}}" class="badge">点击10次激活</text>
      <text wx:else class="badge admin-badge">✅ 已激活</text>
    </text>
    <!-- 显示点击进度（仅未激活时） -->
    <text wx:if="{{!isAdmin && tapCount > 0}}" class="tap-progress">
      已点击 {{tapCount}}/10
    </text>
  </view>
</view>

<!-- ===== 权限提示（未激活时显示） ===== -->
<view wx:if="{{!isAdmin}}" class="auth-tip">
  <text>🔑 连续点击“应到天数”卡片 10 次可开启管理员权限</text>
</view>

<!-- ===== 管理员功能（仅激活后显示） ===== -->
<block wx:if="{{isAdmin}}">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item">
      <text class="label">起始日期</text>
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="picker">{{startDate || '请选择'}}</view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="label">结束日期</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="picker">{{endDate || '请选择'}}</view>
      </picker>
    </view>
    <view class="filter-item">
      <text class="label">选择用户</text>
      <picker mode="selector" range="{{userList}}" range-key="name" bindchange="onUserChange">
        <view class="picker">{{selectedUserName || '全部用户'}}</view>
      </picker>
    </view>
    <button class="btn-filter" bindtap="loadData">🔍 查询</button>
  </view>

  <!-- 记录列表 -->
  <view class="record-table">
    <view class="table-header">
      <text class="col-date">日期</text>
      <text class="col-user">用户</text>
      <text class="col-time">进入</text>
      <text class="col-time">离开</text>
      <text class="col-duration">时长</text>
    </view>
    <scroll-view scroll-y class="table-body">
      <view wx:if="{{filteredRecords.length === 0}}" class="empty-tip">
        📭 暂无匹配记录
      </view>
      <view wx:for="{{filteredRecords}}" wx:key="index" class="table-row">
        <text class="col-date">{{item.date}}</text>
        <text class="col-user">{{item.userName}}</text>
        <text class="col-time">{{item.inTime || '--'}}</text>
        <text class="col-time">{{item.outTime || '--'}}</text>
        <text class="col-duration">{{item.duration || '--'}}</text>
      </view>
    </scroll-view>
  </view>
</block>

</view>